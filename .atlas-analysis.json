  "keyFeatures": [
    "Bill payments — airtime, data, electricity, cable TV, and more",
    "Bank transfers with real-time account validation",
    "Virtual bank accounts for collections",
    "Card payments with OTP and 3DS authentication (Visa, Mastercard, Verve)",
    "USSD payment generation",
    "OPay payment collection",
    "Invoice creation and payment with PDF download",
    "Recurring subscriptions with virtual account support",
    "Customer management with dedicated virtual accounts",
    "KYC identity verification — BVN, NIN, CAC, drivers license, passport",
    "Crypto wallet creation and transfers",
    "Webhook notifications for async payment events",
    "API key authentication with rate limiting and IP whitelisting"
  ],
